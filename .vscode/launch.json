{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run RoSync Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "${workspaceFolder}/examples/dev-project"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/dist/**/*.js"
      ],
      "preLaunchTask": "RoSync Daemon: Watch"
    }
  ]
}
