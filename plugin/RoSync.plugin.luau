			if success then
				return result
			end
		end
	
		if encodedType == "BrickColor" and type(encodedValue) == "number" then
			local success, result = pcall(function()
				return BrickColor.new(encodedValue)
			end)
			if success then
				return result
			end
		end
	
		if encodedType == "EnumItem" then
			return decodeEnumItem(encodedValue)
