			serviceIndex = stage.serviceIndex,
			serviceCount = stage.serviceCount,
			detail = stage.detail,
		})
	end
	
	local function serializePushBatchInstance(instance)
		local serialized = Serializer.serializeInstance(instance, false)
		serialized.children = serialized.children or {}
	
		if instance ~= nil and instance.Parent == game then
			serialized.children = {}
			for _, child in ipairs(safeGetChildren(instance)) do
				if shouldSyncInstance(child) then
					table.insert(serialized.children, Serializer.serializeInstance(child, false))
				end
			end
		end
	
		return serialized
	end
	
	local function copySortedTags(tags)
		local sorted = {}
		for _, tag in ipairs(tags or {}) do
			if type(tag) == "string" then
				table.insert(sorted, tag)
			end
		end
		table.sort(sorted)
		return sorted
	end
	
	local function shallowNodeSnapshot(node)
		if type(node) ~= "table" then
			return nil
		end
	
		return {
			className = node.className,
			properties = node.properties or {},
			attributes = node.attributes or {},
			tags = copySortedTags(node.tags),
			source = node.source,
		}
	end
	
	local function isSequentialArray(value)
		if type(value) ~= "table" then
			return false
		end
	
		local count = 0
		for key in pairs(value) do
			if type(key) ~= "number" then
				return false
			end
			count += 1
		end
	
		for index = 1, count do
			if value[index] == nil then
				return false
			end
		end
	
		return true
	end
	
	local function valuesEquivalent(left, right)
		if left == right then
			return true
		end
	
		local leftType = type(left)
		if leftType ~= type(right) then
			return false
		end
	
		if leftType ~= "table" then
			return false
		end
	
		local leftIsArray = isSequentialArray(left)
		local rightIsArray = isSequentialArray(right)
		if leftIsArray or rightIsArray then
			if not leftIsArray or not rightIsArray or #left ~= #right then
				return false
			end
	
			for index, leftValue in ipairs(left) do
				if not valuesEquivalent(leftValue, right[index]) then
					return false
				end
			end
	
			return true
		end
	
		local seenKeys = {}
		for key, leftValue in pairs(left) do
			seenKeys[key] = true
			if not valuesEquivalent(leftValue, right[key]) then
				return false
			end
		end
	
		for key, rightValue in pairs(right) do
			if not seenKeys[key] and rightValue ~= nil then
				return false
			end
		end
	
		return true
	end
	
	local function indexRemoteTreeNode(node, snapshotIndex)
		if type(node) ~= "table" or type(node.path) ~= "string" then
			return
		end
	
		snapshotIndex[node.path] = shallowNodeSnapshot(node)
		for _, childNode in ipairs(node.children or {}) do
			indexRemoteTreeNode(childNode, snapshotIndex)
		end
	end
	
	local function buildRemoteTreeSnapshotIndex(tree)
		local snapshotIndex = {}
		if type(tree) ~= "table" or type(tree.services) ~= "table" then
			return snapshotIndex
		end
	
		for _, serviceNode in ipairs(tree.services) do
			indexRemoteTreeNode(serviceNode, snapshotIndex)
		end
	
		return snapshotIndex
	end
	
	local function buildRemoteServicePathIndex(tree)
		local servicePathIndex = {}
		if type(tree) ~= "table" or type(tree.services) ~= "table" then
			return servicePathIndex
		end
	
		local function visit(node, serviceName)
			if type(node) ~= "table" or type(node.path) ~= "string" then
				return
			end
	
			local nextServiceName = serviceName or node.path
			local pathSet = servicePathIndex[nextServiceName]
			if type(pathSet) ~= "table" then
				pathSet = {}
				servicePathIndex[nextServiceName] = pathSet
			end
	
			pathSet[node.path] = true
			for _, childNode in ipairs(node.children or {}) do
				visit(childNode, nextServiceName)
			end
		end
	
		for _, serviceNode in ipairs(tree.services) do
			visit(serviceNode, nil)
		end
	
		return servicePathIndex
	end
	
	local function countPathDepth(pathValue)
		local depth = 1
		for _ in string.gmatch(pathValue, "/") do
			depth += 1
		end
		return depth
	end
	
	local function isSameOrDescendantPath(candidatePath, ancestorPath)
		return candidatePath == ancestorPath or string.sub(candidatePath, 1, #ancestorPath + 1) == ancestorPath .. "/"
	end
	
	local function isProtectedSyncPath(pathValue)
		for protectedPath in pairs(READ_ONLY_SYNC_PATHS) do
			if isSameOrDescendantPath(pathValue, protectedPath) then
				return true
			end
		end
	
		return false
	end
	
	local function collectServiceInstances(serviceName)
		local service = game:FindService(serviceName)
		local instances = {}
		if not service then
			return instances
		end
	
		for _, descendant in ipairs(service:GetDescendants()) do
			if shouldSyncInstance(descendant) then
				table.insert(instances, descendant)
			end
		end
	
		if shouldSyncInstance(service) then
			table.insert(instances, 1, service)
		end
	
		return instances
	end
	
	local function buildLocalServiceManifest(serviceName)
		local instances = collectServiceInstances(serviceName)
		local manifest = {
			scanned = #instances,
			pathSet = {},
			snapshotIndex = {},
			pullPathSet = {},
			pullSnapshotIndex = {},
			instanceByPath = {},
		}
	
		for index, instance in ipairs(instances) do
			local instancePath = PathUtil.getInstancePath(instance)
			local serialized = serializePushBatchInstance(instance)
			local snapshot = shallowNodeSnapshot(serialized)
	
			manifest.pathSet[instancePath] = true
			manifest.snapshotIndex[instancePath] = snapshot
			manifest.instanceByPath[instancePath] = instance
	
			if not isProtectedSyncPath(instancePath) then
				manifest.pullPathSet[instancePath] = true
				manifest.pullSnapshotIndex[instancePath] = snapshot
			end
	
			if index % 200 == 0 then
				task.wait()
			end
		end
	
		return manifest
	end
	
	local function getLocalServiceManifest(serviceName)
		local cachedManifest = serviceManifestCache[serviceName]
		if cachedManifest ~= nil and dirtyServiceNames[serviceName] ~= true then
			return cachedManifest
		end
	
		local manifest = buildLocalServiceManifest(serviceName)
		serviceManifestCache[serviceName] = manifest
		dirtyServiceNames[serviceName] = false
		return manifest
	end
	
	local function selectServiceRemovalPaths(serviceName, localPathSet, remoteServicePathIndex)
		local removalPaths = {}
		if type(remoteServicePathIndex) ~= "table" then
			return removalPaths
		end
	
		local remotePathSet = remoteServicePathIndex[serviceName]
		if type(remotePathSet) ~= "table" then
			return removalPaths
		end
	
		local missingPaths = {}
		for remotePath in pairs(remotePathSet) do
			if remotePath ~= serviceName and localPathSet[remotePath] ~= true then
				table.insert(missingPaths, remotePath)
			end
		end
	
		table.sort(missingPaths, function(left, right)
			local depthDifference = countPathDepth(left) - countPathDepth(right)
			if depthDifference ~= 0 then
				return depthDifference < 0
			end
			return left < right
		end)
	
		local selectedPaths = {}
		for _, remotePath in ipairs(missingPaths) do
			local covered = false
			for _, selectedPath in ipairs(selectedPaths) do
				if isSameOrDescendantPath(remotePath, selectedPath) then
					covered = true
					break
				end
			end
	
			if not covered then
				table.insert(selectedPaths, remotePath)
				table.insert(removalPaths, remotePath)
			end
		end
	
		return removalPaths
	end
	
	local function selectStudioRemovalPaths(serviceName, localPathSet, remoteServicePathIndex)
		local removalPaths = {}
		local remotePathSet = type(remoteServicePathIndex) == "table" and remoteServicePathIndex[serviceName] or nil
		if type(remotePathSet) ~= "table" then
			return removalPaths
		end
	
		local missingPaths = {}
		for localPath in pairs(localPathSet) do
			if localPath ~= serviceName and remotePathSet[localPath] ~= true then
				table.insert(missingPaths, localPath)
			end
		end
	
		table.sort(missingPaths, function(left, right)
			local depthDifference = countPathDepth(left) - countPathDepth(right)
			if depthDifference ~= 0 then
				return depthDifference < 0
			end
			return left < right
		end)
	
		local selectedPaths = {}
		for _, localPath in ipairs(missingPaths) do
			local covered = false
			for _, selectedPath in ipairs(selectedPaths) do
				if isSameOrDescendantPath(localPath, selectedPath) then
					covered = true
					break
				end
			end
	
			if not covered then
				table.insert(selectedPaths, localPath)
				table.insert(removalPaths, localPath)
			end
		end
	
		return removalPaths
	end
	
	local function summarizePushServicePlan(serviceName, remoteSnapshotIndex, remoteServicePathIndex)
		local manifest = getLocalServiceManifest(serviceName)
		local entries = {}
		local addedCount = 0
		local changedCount = 0
		local scannedCount = 0
	
		for instancePath, localSnapshot in pairs(manifest.snapshotIndex) do
			scannedCount += 1
			local remoteSnapshot = type(remoteSnapshotIndex) == "table" and remoteSnapshotIndex[instancePath] or nil
			if not valuesEquivalent(localSnapshot, remoteSnapshot) then
				local instance = manifest.instanceByPath[instancePath]
				local serialized = instance and serializePushBatchInstance(instance) or nil
				if serialized then
					table.insert(entries, {
						path = instancePath,
						data = serialized,
					})
					if type(remoteSnapshot) == "table" then
						changedCount += 1
					else
						addedCount += 1
					end
				end
			end
			if scannedCount % 200 == 0 then
				task.wait()
			end
		end
	
		local removalPaths = selectServiceRemovalPaths(serviceName, manifest.pathSet, remoteServicePathIndex)
		return {
			name = serviceName,
			scanned = manifest.scanned,
			added = addedCount,
			changed = changedCount,
			removed = #removalPaths,
			unchanged = math.max(0, manifest.scanned - addedCount - changedCount),
			entries = entries,
			removalPaths = removalPaths,
		}
	end
	
	local function summarizePullServicePlan(serviceName, remoteSnapshotIndex, remoteServicePathIndex)
		local manifest = getLocalServiceManifest(serviceName)
		local remotePathSet = type(remoteServicePathIndex) == "table" and remoteServicePathIndex[serviceName] or nil
		local addedCount = 0
		local changedCount = 0
		local unchangedCount = 0
	
		local scannedRemoteCount = 0
		for remotePath in pairs(remotePathSet or {}) do
			if not isProtectedSyncPath(remotePath) then
				local localSnapshot = manifest.pullSnapshotIndex[remotePath]
				local remoteSnapshot = type(remoteSnapshotIndex) == "table" and remoteSnapshotIndex[remotePath] or nil
				if localSnapshot == nil then
					addedCount += 1
				elseif not valuesEquivalent(localSnapshot, remoteSnapshot) then
					changedCount += 1
				else
					unchangedCount += 1
				end
			end
			scannedRemoteCount += 1
			if scannedRemoteCount % 200 == 0 then
				task.wait()
			end
		end
	
		local removalPaths = selectStudioRemovalPaths(serviceName, manifest.pullPathSet, remoteServicePathIndex)
		return {
			name = serviceName,
			scanned = manifest.scanned,
			added = addedCount,
			changed = changedCount,
			removed = #removalPaths,
			unchanged = unchangedCount,
			removalPaths = removalPaths,
		}
	end
	
	local function appendServicePlan(direction, plan)
		local serviceName = plan.name or plan.service or "Service"
		if (plan.added or 0) == 0 and (plan.changed or 0) == 0 and (plan.removed or 0) == 0 then
			appendInfo(
				string.format(
					"%s plan for %s - no changes (%d unchanged).",
					direction == "push" and "Push" or "Pull",
					serviceName,
					plan.unchanged or 0
				)
			)
			return
		end
	
		appendInfo(
			string.format(
				"%s plan for %s - %d added, %d changed, %d removed, %d unchanged.",
				direction == "push" and "Push" or "Pull",
				serviceName,
				plan.added or 0,
				plan.changed or 0,
				plan.removed or 0,
				plan.unchanged or 0
			)
		)
	end
	
	local function broadcastServicePlan(direction, plan, serviceIndex, serviceCount)
		appendServicePlan(direction, plan)
		sendSyncPlan({
			direction = direction,
			service = plan.name,
			added = plan.added or 0,
			changed = plan.changed or 0,
			removed = plan.removed or 0,
			unchanged = plan.unchanged or 0,
			scanned = plan.scanned or 0,
			serviceIndex = serviceIndex,
			serviceCount = serviceCount,
			planComplete = serviceIndex == serviceCount,
		})
	end
	
	local function fetchAndApplyTree(reason, options)
		if refreshInFlight then
			refreshQueued = true
			return
		end
	
		refreshInFlight = true
		httpClient:setBaseUrl(currentServerUrl())
	
		local success, response = httpClient:getTree()
		if not success then
			appendLog("Tree fetch failed (" .. tostring(reason) .. "): " .. tostring(response), "warn")
			refreshInFlight = false
			return
		end
	
		local applyOptions = nil
		local shouldLogProgress = type(options) == "table" and options.logProgress == true
		local shouldReconcileRemovals = type(options) == "table" and options.reconcileRemovals == true
		local remoteSnapshotIndex = nil
		local remoteServicePathIndex = nil
		if type(response.tree) == "table" then
			remoteSnapshotIndex = buildRemoteTreeSnapshotIndex(response.tree)
			remoteServicePathIndex = buildRemoteServicePathIndex(response.tree)
		end
	
		if shouldLogProgress or shouldReconcileRemovals then
			setTransferState("Planning Pull", "Comparing Studio state against disk.", PULL_PURPLE)
			appendInfo("Building Pull All plan service by service...")
			for serviceIndex, serviceName in ipairs(SYNC_SERVICES) do
				local planningDetail = string.format("Comparing %s (%d/%d).", serviceName, serviceIndex, #SYNC_SERVICES)
				setTransferState("Planning Pull " .. tostring(serviceName), planningDetail, PULL_PURPLE)
				appendInfo(string.format("Planning Pull for %s (%d/%d)...", serviceName, serviceIndex, #SYNC_SERVICES))
				sendSyncStage({
					direction = "pull",
					phase = "planning",
					service = serviceName,
					serviceIndex = serviceIndex,
					serviceCount = #SYNC_SERVICES,
					detail = "Comparing Studio state against disk.",
				})
				local plan = summarizePullServicePlan(serviceName, remoteSnapshotIndex, remoteServicePathIndex)
				broadcastServicePlan("pull", plan, serviceIndex, #SYNC_SERVICES)
				task.wait()
			end
			appendInfo("Pull plan ready. Applying disk state to Studio...")
		end
	
		if shouldLogProgress or shouldReconcileRemovals then
			local serviceCount = #(response.tree.services or {})
			applyOptions = {
				reconcileRemovals = shouldReconcileRemovals,
				batchSize = 50,
				onProgress = function(done, total)
					setTransferState("Pulling", string.format("%d/%d instances applied to Studio", done, total), PULL_PURPLE)
				end,
				onServiceStart = function(serviceName, total)
					setTransferState("Pulling " .. tostring(serviceName), string.format("0/%d instances applied to Studio", total), PULL_PURPLE)
					appendInfo(string.format("Pulling %s (%d instances)...", serviceName, total))
					sendSyncStage({
						direction = "pull",
						phase = "applying",
						service = serviceName,
						detail = "Applying disk state to Studio.",
					})
					sendPullProgress({
						service = serviceName,
						done = 0,
						total = total,
						serviceComplete = false,
						pullComplete = false,
					})
				end,
				onServiceProgress = function(serviceName, done, total)
					setTransferState("Pulling " .. tostring(serviceName), string.format("%d/%d instances applied to Studio", done, total), PULL_PURPLE)
					sendPullProgress({
						service = serviceName,
						done = done,
						total = total,
						serviceComplete = false,
						pullComplete = false,
					})
				end,
				onServiceComplete = function(serviceName, done, total, isLastService, removedCount)
					local pullComplete = isLastService == true or serviceCount <= 1
					local detailText = string.format("%d/%d instances applied to Studio", done, total)
					if type(removedCount) == "number" and removedCount > 0 then
						detailText = detailText .. string.format(" + %d removed", removedCount)
					end
	
					setTransferState("Pulling " .. tostring(serviceName), detailText, PULL_PURPLE)
					if type(removedCount) == "number" and removedCount > 0 then
						appendInfo(string.format("Pulled %s (%d applied, %d removed).", serviceName, done, removedCount))
					else
						appendInfo(string.format("Pulled %s (%d instances).", serviceName, done))
					end
					sendPullProgress({
						service = serviceName,
						done = done,
						total = total,
						serviceComplete = true,
						pullComplete = pullComplete,
					})
				end,
			}
		end
	
		applyInProgress = true
		local applied, applyError, appliedCount, removedCount = Deserializer.applyTree(response.tree, applyOptions)
		applyInProgress = false
		invalidateAllServiceManifests()
	
		if applied and shouldLogProgress then
			if type(removedCount) == "number" and removedCount > 0 then
				appendInfo(string.format("Pull All complete - %d instances applied, %d removed", appliedCount or 0, removedCount))
				setTransferState(
					"Ready",
					string.format("Pulled %d instances into Studio and removed %d stale instances.", appliedCount or 0, removedCount),
					STATUS_CONNECTED
				)
			else
				appendInfo(string.format("Pull All complete - %d instances applied", appliedCount or 0))
				setTransferState("Ready", string.format("Pulled %d instances into Studio.", appliedCount or 0), STATUS_CONNECTED)
			end
		elseif applied and reason ~= "poll" then
			appendLog("Applied daemon tree (" .. tostring(reason) .. ").")
		elseif not applied then
			appendLog("Tree apply failed (" .. tostring(reason) .. "): " .. tostring(applyError), "warn")
			setTransferState("Needs Attention", tostring(applyError or "Tree apply failed."), STATUS_CONFLICT)
		end
	
		refreshInFlight = false
	
		if refreshQueued then
			refreshQueued = false
			task.defer(function()
				fetchAndApplyTree("queued")
			end)
		end
	end
	
	local function syncAfterHandshake()
		httpClient:setBaseUrl(currentServerUrl())
		resetTransferState()
	
		local statusOk, statusResponse = httpClient:request("GET", "/status")
		if statusOk then
			local indexedInstances = daemonIndexedInstanceCount(statusResponse)
			if indexedInstances == 0 then
				appendInfo("Daemon has 0 indexed instances — pulling Studio state to disk instead of applying empty daemon state.")
				pushAll()
				return
			end
		elseif statusResponse ~= nil then
			appendInfo("Status check failed during connect: " .. tostring(statusResponse), "warn")
		end
	
		fetchAndApplyTree("welcome")
	end
	
	local function startPolling(reason)
		if pollingThread then
			return
		end
	
		appendLog("HTTP polling active (" .. tostring(reason) .. ").")
		pollingThread = task.spawn(function()
			while desiredConnection and (not socketClient or not socketClient:isConnected()) do
				fetchAndApplyTree("poll")
				task.wait(2)
			end
			pollingThread = nil
		end)
	end
	
	local function scheduleReconnect()
		if not desiredConnection or reconnectThread then
			return
		end
	
		local delaySeconds = math.min(30, 2 ^ reconnectAttempt)
		reconnectAttempt += 1
		setStatus("reconnecting")
		appendLog("Scheduling reconnect in " .. tostring(delaySeconds) .. "s.")
		reconnectThread = task.delay(delaySeconds, function()
			reconnectThread = nil
			if desiredConnection then
				connectSocket(true)
			end
		end)
	end
	
	local function handleSocketMessage(message)
		local success, payload = pcall(function()
			return HttpService:JSONDecode(message)
		end)
	
		if not success or type(payload) ~= "table" then
			return
		end
	
		if payload.type == "WELCOME" then
			reconnectAttempt = 0
			stopPolling()
			appendInfo("Daemon handshake complete. Studio is now connected over WebSocket.")
			syncAfterHandshake()
			return
		end
	
		if payload.type == "PROJECT_TREE" and type(payload.tree) == "table" then
			applyInProgress = true
			local applied, applyError = Deserializer.applyTree(payload.tree)
			applyInProgress = false
			invalidateAllServiceManifests()
	
			if applied then
				appendInfo("Applied daemon project tree.")
			else
				appendInfo("Project tree apply failed: " .. tostring(applyError), "warn")
			end
			return
		end
	
		if payload.type == "PUSH_REQUEST" then
			fetchAndApplyTree("push-request", {
				logProgress = true,
				reconcileRemovals = true,
			})
			return
		end
	
		if payload.type == "PULL_REQUEST" then
			pushAll()
			return
		end
	
		if payload.type == "SYNC_INSTANCE" and type(payload.path) == "string" and type(payload.data) == "table" then
			local existedBefore = instanceExistsAtPath(payload.path)
			applyInProgress = true
			local applied, applyError = Deserializer.applySyncInstance(payload.path, payload.data)
			applyInProgress = false
			markPathDirty(payload.path)
	
			if applied then
				if existedBefore then
					if shouldLogIncomingUpdate(payload) then
						appendEvent(payload.origin, "update", payload.path)
					end
				else
					appendEvent(payload.origin, "add", payload.path)
				end
			else
				appendInfo("Sync apply failed for " .. payload.path .. ": " .. tostring(applyError), "warn")
			end
			return
		end
	
		if payload.type == "REMOVE_INSTANCE" and type(payload.path) == "string" then
			applyInProgress = true
			local removed, removeError = Deserializer.removeAtPath(payload.path)
			applyInProgress = false
			markPathDirty(payload.path)
	
			if removed then
				appendEvent(payload.origin, "remove", payload.path)
			else
				appendInfo("Remove failed for " .. payload.path .. ": " .. tostring(removeError), "warn")
			end
			return
		end
	
		if payload.type == "RENAME_INSTANCE" and type(payload.oldPath) == "string" and type(payload.newPath) == "string" then
			applyInProgress = true
			local renamed, renameError = Deserializer.renameAtPath(payload.oldPath, payload.newPath)
			applyInProgress = false
			markPathDirty(payload.oldPath)
			markPathDirty(payload.newPath)
	
			if renamed then
				appendEvent(payload.origin, classifyPathMutation(payload.oldPath, payload.newPath), payload.oldPath, payload.newPath)
			else
				appendInfo("Rename failed for " .. payload.oldPath .. ": " .. tostring(renameError), "warn")
			end
			return
		end
	
		if payload.type == "FILE_SYSTEM_CHANGED"
			or payload.type == "INSTANCE_ADDED"
			or payload.type == "INSTANCE_CHANGED"
			or payload.type == "INSTANCE_REMOVED"
			or payload.type == "INSTANCE_RENAMED" then
			fetchAndApplyTree(payload.type)
			return
		end
	
		if payload.type == "CONFLICT" then
			setStatus("conflict")
			appendInfo("Conflict: " .. tostring(payload.reason or payload.path), "warn")
			return
		end
	
		if payload.type == "ERROR" then
			appendInfo("Daemon error: " .. tostring(payload.message), "warn")
		end
	end
	
	connectSocket = function(isReconnect)
		httpClient:setBaseUrl(currentServerUrl())
		cancelReconnect()
	
		socketClient = WebSocketClient.new(currentServerUrl(), {
			onOpen = function()
				appendLog("WebSocket opened.")
			end,
			onMessage = handleSocketMessage,
			onError = function(responseStatusCode, errorMessage)
				appendLog(
					"WebSocket error"
						.. (responseStatusCode and responseStatusCode > 0 and (" (" .. tostring(responseStatusCode) .. ")") or "")
						.. ": "
						.. tostring(errorMessage),
					"warn"
				)
			end,
			onClose = function(wasConnected)
				if socketClient then
					socketClient:close()
					socketClient = nil
				end
				if desiredConnection then
					setStatus("disconnected")
					appendLog(
						wasConnected and "WebSocket closed. Falling back to HTTP polling."
							or "WebSocket closed before the daemon handshake completed. Falling back to HTTP polling.",
						"warn"
					)
					if not suppressNextSocketCloseOutput then
						writeStudioOutput("Connection lost from RoSync daemon.")
					end
					suppressNextSocketCloseOutput = false
					startPolling("socket-closed")
					scheduleReconnect()
					return
				end
				stopPolling()
				setStatus("disconnected")
				appendLog("WebSocket closed.")
				if not suppressNextSocketCloseOutput then
					writeStudioOutput("Connection lost from RoSync daemon.")
				end
				suppressNextSocketCloseOutput = false
			end,
		})
	
		local connected, errorMessage = socketClient:connect()
		if not connected then
			socketClient = nil
			appendLog("WebSocket connect failed: " .. tostring(errorMessage), "warn")
			appendConnectionHint()
			setStatus("disconnected")
			startPolling(isReconnect and "reconnect-fallback" or "initial-fallback")
			scheduleReconnect()
			return false
		end
	
		stopPolling()
		local helloSent = sendMessage({
			type = "HELLO",
			version = "0.1.0",
			client = "studio",
			clientId = clientId,
		})
		if not helloSent then
			appendLog("Connected transport, but HELLO could not be sent.", "warn")
		end
	
		setStatus("connected")
		appendLog("Connected to RoSync daemon at " .. currentServerUrl() .. ".")
		writeStudioOutput("Connection established with RoSync daemon at " .. currentServerUrl() .. ".")
		return true
	end
	
	local function pushInstance(instance, action, shouldLogEvent, propertyName)
		markInstanceDirty(instance)
		local serialized = serializeSyncTree(instance)
		if not serialized then
			return false
		end
	
		local instancePath = PathUtil.getInstancePath(instance)
		local sent = sendMessage({
			type = "SYNC_INSTANCE",
			path = instancePath,
			data = serialized,
		})
	
		if sent and shouldLogEvent and (action ~= "update" or shouldLogStudioUpdate(instance, propertyName)) then
			appendEvent("studio", action or "update", instancePath)
		end
	
		return sent
	end
	
	local function flushPushBatch(batch, removedPaths, progress)
		local normalizedBatch = batch or {}
		local normalizedRemovedPaths = removedPaths or {}
		if #normalizedBatch == 0 and #normalizedRemovedPaths == 0 then
			return true
		end
	
		local payload = {
			type = "PUSH_BATCH",
			instances = normalizedBatch,
			removedPaths = normalizedRemovedPaths,
		}
	
		if type(progress) == "table" then
			payload.service = progress.service
			payload.done = progress.done
			payload.total = progress.total
			payload.serviceComplete = progress.serviceComplete == true
			payload.pushComplete = progress.pushComplete == true
		end
	
		return sendMessage(payload)
	end
	
	pushAll = function()
		if not isSyncAllowed("Push All") then
			return
		end
	
		if not socketClient or not socketClient:isConnected() then
			appendInfo("Push All requires an active daemon connection.", "warn")
			return
		end
	
		appendInfo("Starting Push All...")
		setTransferState("Planning Push", "Comparing Studio state against disk.", PUSH_ORANGE)
		httpClient:setBaseUrl(currentServerUrl())
	
		local remoteSnapshotIndex = nil
		local remoteServicePathIndex = nil
		local treeOk, treeResponse = httpClient:getTree()
		if treeOk and type(treeResponse) == "table" and type(treeResponse.tree) == "table" then
			remoteSnapshotIndex = buildRemoteTreeSnapshotIndex(treeResponse.tree)
			remoteServicePathIndex = buildRemoteServicePathIndex(treeResponse.tree)
			appendInfo("Comparing Studio state with the daemon tree before Push All.")
		else
			appendInfo("Daemon tree compare failed. Falling back to full Push All.", "warn")
		end
	
		local batchSize = 50
		local scannedTotal = 0
		local addedTotal = 0
		local changedTotal = 0
		local removedTotal = 0
		local servicePlans = {}
		appendInfo("Building Push All plan service by service...")
	
		for serviceIndex, serviceName in ipairs(SYNC_SERVICES) do
			local planningDetail = string.format("Comparing %s (%d/%d).", serviceName, serviceIndex, #SYNC_SERVICES)
			setTransferState("Planning Push " .. tostring(serviceName), planningDetail, PUSH_ORANGE)
			appendInfo(string.format("Planning Push for %s (%d/%d)...", serviceName, serviceIndex, #SYNC_SERVICES))
			sendSyncStage({
				direction = "push",
				phase = "planning",
				service = serviceName,
				serviceIndex = serviceIndex,
				serviceCount = #SYNC_SERVICES,
				detail = "Comparing Studio state against disk.",
			})
			local plan = summarizePushServicePlan(serviceName, remoteSnapshotIndex, remoteServicePathIndex)
			broadcastServicePlan("push", plan, serviceIndex, #SYNC_SERVICES)
			scannedTotal += plan.scanned
			addedTotal += plan.added
			changedTotal += plan.changed
			removedTotal += plan.removed
			if #plan.entries > 0 or #plan.removalPaths > 0 then
				table.insert(servicePlans, plan)
			end
			task.wait()
		end
	
		if #servicePlans == 0 then
			appendInfo(string.format("Push All already matches disk - no changed instances found across %d checked entries.", scannedTotal))
			setTransferState("Ready", "Studio already matches disk.", STATUS_CONNECTED)
			return
		end
	
		appendInfo("Push plan ready. Exporting Studio changes to disk...")
	
		for serviceIndex, plan in ipairs(servicePlans) do
			local serviceName = plan.name
			local entries = plan.entries
			local removalPaths = plan.removalPaths
			local differenceCount = #entries + #removalPaths
			sendSyncStage({
				direction = "push",
				phase = "applying",
				service = serviceName,
				serviceIndex = serviceIndex,
				serviceCount = #servicePlans,
				detail = "Exporting Studio changes to disk.",
			})
			appendInfo(
				string.format(
					"Pushing %s (%d added, %d changed, %d removed of %d checked)...",
					serviceName,
					plan.added,
					plan.changed,
					#removalPaths,
					plan.scanned
				)
			)
			setTransferState("Pushing " .. tostring(serviceName), string.format("0/%d changes exported to disk", differenceCount), PUSH_ORANGE)
	
			local processedCount = 0
			local batch = {}
			for index, entry in ipairs(entries) do
				table.insert(batch, entry)
	
				if #batch >= batchSize or index == #entries then
					local nextDone = processedCount + #batch
					setTransferState(
						"Pushing " .. tostring(serviceName),
						string.format("%d/%d changes exported to disk", nextDone, differenceCount),
						PUSH_ORANGE
					)
					local sent = flushPushBatch(batch, {}, {
						service = serviceName,
						done = nextDone,
						total = differenceCount,
						serviceComplete = nextDone == differenceCount,
						pushComplete = nextDone == differenceCount and serviceIndex == #servicePlans,
					})
					if not sent then
						appendInfo("Push All batch send failed.", "warn")
					end
	
					processedCount = nextDone
					batch = {}
					task.wait(0.05)
				end
			end
	
			local removalBatch = {}
			for index, removalPath in ipairs(removalPaths) do
				table.insert(removalBatch, removalPath)
	
				if #removalBatch >= batchSize or index == #removalPaths then
					local nextDone = processedCount + #removalBatch
					setTransferState(
						"Pushing " .. tostring(serviceName),
						string.format("%d/%d changes exported to disk", nextDone, differenceCount),
						PUSH_ORANGE
					)
					local sent = flushPushBatch({}, removalBatch, {
						service = serviceName,
						done = nextDone,
						total = differenceCount,
						serviceComplete = nextDone == differenceCount,
						pushComplete = nextDone == differenceCount and serviceIndex == #servicePlans,
					})
					if not sent then
						appendInfo("Push All removal batch send failed.", "warn")
					end
	
					processedCount = nextDone
					removalBatch = {}
					task.wait(0.05)
				end
			end
	
			appendInfo(
				string.format(
					"%s - pushed %d added, %d changed, and removed %d stale instances",
					serviceName,
					plan.added,
					plan.changed,
					#removalPaths
				)
			)
		end
	
		appendInfo(
			string.format(
				"Push All complete - %d added, %d changed, and %d stale instances removed after checking %d total instances",
				addedTotal,
				changedTotal,
				removedTotal,
				scannedTotal
			)
		)
		setTransferState(
			"Ready",
			string.format("Applied %d Studio changes into the daemon.", addedTotal + changedTotal + removedTotal),
			STATUS_CONNECTED
		)
	end
	
	local function startWatch()
		if not isSyncAllowed("Watch") then
			return
		end
	
		if stopWatching then
			appendLog("Watch is already running.")
			return
		end
	
		stopWatching = Listener.attach(function(instance)
			return instance ~= nil and instance ~= game and not applyInProgress
		end, {
			onAdded = function(instance)
				markInstanceDirty(instance)
				pushInstance(instance, "add", true)
			end,
			onChanged = function(instance, propertyName)
				markInstanceDirty(instance)
				pushInstance(instance, "update", true, propertyName)
			end,
			onRenamed = function(instance, oldPath, newPath)
				markPathDirty(oldPath)
				markPathDirty(newPath)
				local serialized = Serializer.serializeInstance(instance, true)
				local sent = sendMessage({
					type = "INSTANCE_RENAMED",
					oldPath = oldPath,
					newPath = newPath,
					data = serialized,
				})
				if sent then
					appendEvent("studio", classifyPathMutation(oldPath, newPath), oldPath, newPath)
				end
			end,
			onRemoving = function(_, previousPath)
				markPathDirty(previousPath)
				local sent = sendMessage({
					type = "REMOVE_INSTANCE",
					path = previousPath,
				})
				if sent then
					appendEvent("studio", "remove", previousPath)
				end
			end,
		}, {
			debounceSeconds = 0.15,
		})
	
		appendLog("Studio watch started.")
	end
	
	local function stopWatch()
		if stopWatching then
			stopWatching()
			stopWatching = nil
			appendLog("Studio watch stopped.")
		end
	end
	
	local function disconnectFromDaemon()
		desiredConnection = false
		refreshConnectToggle()
		resetTransferState()
		cancelReconnect()
		stopPolling()
		stopWatch()
		if socketClient then
			suppressNextSocketCloseOutput = true
			socketClient:close()
			socketClient = nil
		end
		setStatus("disconnected")
		appendLog("Disconnected from RoSync.")
		writeStudioOutput("Connection lost from RoSync daemon.")
	end
	
	connectToggleButton.MouseButton1Click:Connect(function()
		if desiredConnection then
			disconnectFromDaemon()
			return
		end
	
		httpClient:setBaseUrl(currentServerUrl())
		desiredConnection = true
		refreshConnectToggle()
		setTransferState("Connecting", "Checking daemon health on localhost.", CONNECT_BLUE)
		startWatch()
	
		local success, response = httpClient:getHealth()
		if success then
			appendLog(
				"HTTP health OK for " .. currentServerUrl() .. " (project " .. tostring(response.project or "unknown") .. "). Opening WebSocket..."
			)
			connectSocket(false)
		else
			setStatus("disconnected")
			appendLog("HTTP health failed: " .. tostring(response), "warn")
			appendConnectionHint()
			startPolling("health-check")
			scheduleReconnect()
		end
	end)
	
	pushAllButton.MouseButton1Click:Connect(function()
		if not Listener.isSyncAllowed() then
			appendSyncBlocked()
			return
		end
	
		pushAll()
	end)
	
	pullAllButton.MouseButton1Click:Connect(function()
		if not Listener.isSyncAllowed() then
			appendSyncBlocked()
			return
		end
	
		appendInfo("Starting Pull All...")
		setTransferState("Pulling", "Requesting the daemon tree.", PULL_PURPLE)
		fetchAndApplyTree("pull-all", {
			logProgress = true,
			reconcileRemovals = true,
		})
	end)
	
	statusButton.MouseButton1Click:Connect(function()
		httpClient:setBaseUrl(currentServerUrl())
		local success, response = httpClient:request("GET", "/status")
		if success then
			local connections = response.connections or {}
			local summary = response.summary or {}
			appendLog(
				"Status: project="
					.. tostring(response.project or response.config and response.config.projectName or "unknown")
					.. ", studio="
					.. tostring(connections.studio or 0)
					.. ", editor="
					.. tostring(connections.editor or 0)
					.. ", instances="
					.. tostring(summary.indexedInstances or 0)
			)
		else
			appendLog("Status failed: " .. tostring(response), "warn")
		end
	end)
	
	button.Click:Connect(function()
		widget.Enabled = not widget.Enabled
	end)
	
	refreshConnectToggle()
	setStatus("disconnected")
	resetTransferState()
	appendLog("RoSync plugin ready.")
	writeStudioOutput("RoSync plugin ready.")
	
end

__modules['network/HttpClient'] = function(moduleRequire, script)
	local require = moduleRequire
	local HttpService = game:GetService("HttpService")
	
	local HttpClient = {}
	HttpClient.__index = HttpClient
	
	local function normalizeBaseUrl(baseUrl)
		local trimmed = string.gsub(baseUrl or "", "/+$", "")
		if trimmed == "" then
			return "http://127.0.0.1:34872"
		end
		trimmed = string.gsub(trimmed, "://localhost", "://127.0.0.1")
		return trimmed
	end
	
	function HttpClient.new(baseUrl)
		local self = setmetatable({}, HttpClient)
		self.baseUrl = normalizeBaseUrl(baseUrl)
		return self
	end
	
	function HttpClient:setBaseUrl(baseUrl)
		self.baseUrl = normalizeBaseUrl(baseUrl)
	end
	
	function HttpClient:request(method, route, payload)
		local request = {
			Url = self.baseUrl .. route,
			Method = method,
			Headers = {
				["Content-Type"] = "application/json",
			},
		}
	
		if payload ~= nil then
			request.Body = HttpService:JSONEncode(payload)
		end
	
		local success, response = pcall(function()
			return HttpService:RequestAsync(request)
		end)
	
		if not success then
			return false, tostring(response)
		end
	
		if not response.Success then
			return false, response.Body
		end
	
		local decoded = nil
		if response.Body and response.Body ~= "" then
			local decodeSuccess, decodeResult = pcall(function()
				return HttpService:JSONDecode(response.Body)
			end)
			if decodeSuccess then
				decoded = decodeResult
			end
		end
	
		return true, decoded or {}
	end
	
	function HttpClient:getHealth()
		return self:request("GET", "/health")
	end
	
	function HttpClient:getTree()
		return self:request("GET", "/api/tree")
	end
	
	return HttpClient
	
end

__modules['network/WebSocketClient'] = function(moduleRequire, script)
	local require = moduleRequire
	local HttpService = game:GetService("HttpService")
	
	local WebSocketClient = {}
	WebSocketClient.__index = WebSocketClient
	
	local function normalizeWebSocketUrl(baseUrl)
		local trimmed = string.gsub(baseUrl or "", "/+$", "")
		if trimmed == "" then
			return "ws://127.0.0.1:34872"
		end
	
		trimmed = string.gsub(trimmed, "^http://", "ws://")
		trimmed = string.gsub(trimmed, "^https://", "wss://")
		trimmed = string.gsub(trimmed, "://localhost", "://127.0.0.1")
		return trimmed
	end
	
	function WebSocketClient.new(baseUrl, callbacks)
		local self = setmetatable({}, WebSocketClient)
		self.url = normalizeWebSocketUrl(baseUrl)
		self.callbacks = callbacks or {}
		self.socket = nil
		self.isOpen = false
		self.messageConnection = nil
		self.closeConnection = nil
		self.openConnection = nil
		self.errorConnection = nil
		return self
	end
	
	function WebSocketClient:setBaseUrl(baseUrl)
		self.url = normalizeWebSocketUrl(baseUrl)
	end
	
	local function disconnect(connection)
		if connection then
			connection:Disconnect()
		end
	end
	
	local function isSocketOpen(socket)
		local success, connectionState = pcall(function()
			return socket.ConnectionState
		end)
	
		return success and connectionState == Enum.WebStreamClientState.Open
	end
	
	local function connectionStateLabel(socket)
		local success, connectionState = pcall(function()
			return socket.ConnectionState
		end)
	
		if success and connectionState ~= nil then
			return tostring(connectionState)
		end
	
		return "unknown"
	end
	
	function WebSocketClient:connect()
		if self.socket then
			return self.isOpen, self.isOpen and nil or "WebSocket connection is already opening."
		end
	
		local success, socket = pcall(function()
			return HttpService:CreateWebStreamClient(Enum.WebStreamClientType.WebSocket, {
				Url = self.url,
			})
		end)
	
		if not success then
			return false, tostring(socket)
		end
	
		self.socket = socket
		self.isOpen = false
	
		local settleEvent = Instance.new("BindableEvent")
		local settled = false
	
		local function settle(result, message)
			if settled then
				return
			end
	
			settled = true
			settleEvent:Fire(result, message)
		end
	
		local function markOpen(responseStatusCode, headers)
			if self.isOpen then
				settle(true)
				return
			end
	
			self.isOpen = true
			if self.callbacks.onOpen then
				self.callbacks.onOpen(responseStatusCode, headers)
			end
			settle(true)
		end
	
		self.openConnection = socket.Opened:Connect(function(responseStatusCode, headers)
			markOpen(responseStatusCode, headers)
		end)
	
		self.messageConnection = socket.MessageReceived:Connect(function(message)
			if not self.isOpen and isSocketOpen(socket) then
				markOpen(nil, nil)
			end
	
			if self.callbacks.onMessage then
				self.callbacks.onMessage(message)
			end
		end)
	
		self.errorConnection = socket.Error:Connect(function(responseStatusCode, errorMessage)
			local formatted = tostring(errorMessage)
			if formatted == "" then
				formatted = "WebSocket stream error."
			end
	
			if self.callbacks.onError then
				self.callbacks.onError(responseStatusCode, formatted)
			end
	
			if not self.isOpen then
				settle(false, formatted)
			end
		end)
	
		self.closeConnection = socket.Closed:Connect(function()
			local wasOpen = self.isOpen
			self.isOpen = false
	
			if not settled then
				settle(false, "WebSocket closed before the connection opened.")
			end
	
			if self.callbacks.onClose then
				self.callbacks.onClose(wasOpen)
			end
	
			self:close()
		end)
	
		if isSocketOpen(socket) then
			markOpen(nil, nil)
		end
	
		task.delay(5, function()
			if self.isOpen or isSocketOpen(socket) then
				markOpen(nil, nil)
				return
			end
	
			settle(false, "Timed out waiting for the WebSocket to open (state: " .. connectionStateLabel(socket) .. ").")
		end)
	
		local opened, errorMessage = settleEvent.Event:Wait()
		settleEvent:Destroy()
	
		if not opened then
			self:close()
			return false, errorMessage
		end
	
		return true
	end
	
	function WebSocketClient:isConnected()
		return self.socket ~= nil and self.isOpen
	end
	
	function WebSocketClient:send(payload)
		if not self.socket or not self.isOpen then
			return false, "No WebSocket connection."
		end
	
		local success, result = pcall(function()
			self.socket:Send(HttpService:JSONEncode(payload))
		end)
	
		if not success then
			return false, tostring(result)
		end
	
		return true
	end
	
	function WebSocketClient:close()
		local socket = self.socket
		self.socket = nil
		self.isOpen = false
	
		disconnect(self.messageConnection)
		disconnect(self.closeConnection)
		disconnect(self.openConnection)
		disconnect(self.errorConnection)
	
		self.messageConnection = nil
		self.closeConnection = nil
		self.openConnection = nil
		self.errorConnection = nil
	
		if socket then
			pcall(function()
				socket:Close()
			end)
		end
	end
	
	return WebSocketClient
	
end

__modules['sync/Listener'] = function(moduleRequire, script)
	local require = moduleRequire
	local RunService = game:GetService("RunService")
	local PathUtil = require(script.Parent.Parent.util.PathUtil)
	
	local Listener = {}
	local DEBOUNCE_MS = {
		default = 150,
		script = 1500,
		camera = 99999,
	}
	
	local READ_ONLY_INSTANCES = {
		["Workspace/Camera"] = true,
	}
	
	local ALLOWED_ROOT_SERVICES = {
		Workspace = true,
		Players = true,
		Lighting = true,
		MaterialService = true,
		ReplicatedFirst = true,
		ReplicatedStorage = true,
		ServerScriptService = true,
		ServerStorage = true,
		StarterGui = true,
		StarterPack = true,
		StarterPlayer = true,
		Teams = true,
		SoundService = true,
		TextChatService = true,
	}
	
	local function topLevelAncestor(instance)
		local current = instance
		while current and current.Parent ~= game and current.Parent ~= nil do
			current = current.Parent
		end
	
		return current
	end
	
	local function isAllowedRootService(instance)
		local root = topLevelAncestor(instance)
		if root == nil then
			return false
		end
	
		return ALLOWED_ROOT_SERVICES[root.Name] == true
	end
	
	local function isRuntimePlayerInstance(instance)
		local current = instance
		while current and current ~= game do
			if current:IsA("Player") then
				return true
			end
			current = current.Parent
		end
	
		return false
	end
	
	local function getDebounceMs(instance, propertyName)
		if instance:IsA("LuaSourceContainer") and propertyName == "Source" then
			return DEBOUNCE_MS.script
		end
	
		if instance.ClassName == "Camera" then
			return DEBOUNCE_MS.camera
		end
	
		return DEBOUNCE_MS.default
	end
	
	local function safeReadSource(instance)
		local success, value = pcall(function()
			return instance.Source
		end)
	
		if success and type(value) == "string" then
			return value
		end
	
		return nil
	end
	
	function Listener.isReadOnlyInstance(instance)
		if instance == nil then
			return false
		end
	
		return READ_ONLY_INSTANCES[PathUtil.getInstancePath(instance)] == true
	end
	
	function Listener.isSyncAllowed()
		return not RunService:IsRunning()
	end
	
	function Listener.shouldSyncInstance(instance, shouldSync)
		if instance == nil or instance == game then
			return false
		end
	
		if not Listener.isSyncAllowed() then
			return false
		end
	
		if not isAllowedRootService(instance) then
			return false
		end
	
		if isRuntimePlayerInstance(instance) then
			return false
		end
	
		if type(shouldSync) == "function" then
			return shouldSync(instance)
		end
	
		return true
	end
	
	function Listener.attach(shouldSync, callbacks, options)
		local connections = {}
		local changedConnections = {}
		local nameChangedConnections = {}
		local lastKnownPaths = {}
		local pendingThreads = {}
		local pendingProperties = {}
		local lastSentSource = {}
	
		local function cancelPending(instance)
			local thread = pendingThreads[instance]
			if thread then
				task.cancel(thread)
				pendingThreads[instance] = nil
			end
			pendingProperties[instance] = nil
		end
	
		local function disconnectChanged(instance)
			cancelPending(instance)
			local existing = changedConnections[instance]
			if existing then
				existing:Disconnect()
				changedConnections[instance] = nil
			end
			local nameChanged = nameChangedConnections[instance]
			if nameChanged then
				nameChanged:Disconnect()
				nameChangedConnections[instance] = nil
			end
		end
	
		local function scheduleChanged(instance, propertyName)
			cancelPending(instance)
			pendingProperties[instance] = propertyName
	
			pendingThreads[instance] = task.delay(getDebounceMs(instance, propertyName) / 1000, function()
				pendingThreads[instance] = nil
				local pendingProperty = pendingProperties[instance]
				pendingProperties[instance] = nil
				local currentPath = PathUtil.getInstancePath(instance)
				if not Listener.shouldSyncInstance(instance, shouldSync) then
					lastKnownPaths[instance] = currentPath
					return
				end
	
				local previousPath = lastKnownPaths[instance]
	
				if pendingProperty == "Source" and instance:IsA("LuaSourceContainer") then
					local newSource = safeReadSource(instance)
					if newSource == nil or lastSentSource[instance] == newSource then
						lastKnownPaths[instance] = currentPath
						return
					end
					lastSentSource[instance] = newSource
				end
	
				if previousPath and currentPath ~= previousPath and callbacks.onRenamed then
					callbacks.onRenamed(instance, previousPath, currentPath)
				elseif callbacks.onChanged then
					callbacks.onChanged(instance, pendingProperty)
				end
	
				lastKnownPaths[instance] = currentPath
			end)
		end
	
		local function connectInstance(instance)
			if not Listener.isSyncAllowed() then
				return
			end
	
			if not Listener.shouldSyncInstance(instance, shouldSync) then
				return
			end
	
			if changedConnections[instance] or nameChangedConnections[instance] then
				return
			end
	
			lastKnownPaths[instance] = PathUtil.getInstancePath(instance)
			changedConnections[instance] = instance.Changed:Connect(function(propertyName)
				if propertyName == "Name" then
					return
				end
				scheduleChanged(instance, propertyName)
			end)
			nameChangedConnections[instance] = instance:GetPropertyChangedSignal("Name"):Connect(function()
				if not Listener.isSyncAllowed() then
					return
				end
	
				local previousPath = lastKnownPaths[instance]
				local currentPath = PathUtil.getInstancePath(instance)
				lastKnownPaths[instance] = currentPath
	
				if not previousPath or previousPath == currentPath then
					return
				end
	
				if not Listener.shouldSyncInstance(instance, shouldSync) then
					return
				end
	
				if callbacks.onRenamed then
					callbacks.onRenamed(instance, previousPath, currentPath)
				end
			end)
		end
	
		local function unwatchInstance(instance)
			disconnectChanged(instance)
			lastKnownPaths[instance] = nil
			lastSentSource[instance] = nil
		end
	
		local function onAdded(instance)
			if not Listener.shouldSyncInstance(instance, shouldSync) then
				return
			end
	
			lastKnownPaths[instance] = PathUtil.getInstancePath(instance)
			connectInstance(instance)
			if callbacks.onAdded then
				callbacks.onAdded(instance)
			end
		end
	
		local function onRemoving(instance)
			local previousPath = lastKnownPaths[instance] or PathUtil.getInstancePath(instance)
			if Listener.shouldSyncInstance(instance, shouldSync) and callbacks.onRemoving then
				callbacks.onRemoving(instance, previousPath)
			end
			unwatchInstance(instance)
		end
	
		for _, descendant in ipairs(game:GetDescendants()) do
			if Listener.shouldSyncInstance(descendant, shouldSync) then
				connectInstance(descendant)
			end
		end
	
		for _, child in ipairs(game:GetChildren()) do
			if Listener.shouldSyncInstance(child, shouldSync) then
				connectInstance(child)
			end
		end
	
		table.insert(connections, game.DescendantAdded:Connect(onAdded))
		table.insert(connections, game.DescendantRemoving:Connect(onRemoving))
	
		return function()
			for _, connection in ipairs(connections) do
				connection:Disconnect()
			end
			for instance, connection in pairs(changedConnections) do
				connection:Disconnect()
				changedConnections[instance] = nil
			end
			for instance, connection in pairs(nameChangedConnections) do
				connection:Disconnect()
				nameChangedConnections[instance] = nil
			end
			for instance, pendingThread in pairs(pendingThreads) do
				task.cancel(pendingThread)
				pendingThreads[instance] = nil
			end
			for instance in pairs(pendingProperties) do
				pendingProperties[instance] = nil
			end
			for instance in pairs(lastKnownPaths) do
				lastKnownPaths[instance] = nil
			end
			for instance in pairs(lastSentSource) do
				lastSentSource[instance] = nil
			end
		end
	end
	
	return Listener
	
end

__modules['sync/Serializer'] = function(moduleRequire, script)
	local require = moduleRequire
	local CollectionService = game:GetService("CollectionService")
	local ReflectionService = game:GetService("ReflectionService")
	
	local Serializer = {}
	
	local SCRIPT_CLASS_NAMES = {
		Script = true,
		LocalScript = true,
		ModuleScript = true,
	}
	
	local PROPERTY_DENYLIST = {
		Parent = true,
		Name = true,
		ClassName = true,
		Source = true,
		LinkedSource = true,
		ScriptGuid = true,
		Tags = true,
		Attributes = true,
		AttributesReplicate = true,
		AttributesSerialize = true,
		DataCost = true,
		UniqueId = true,
		HistoryId = true,
		Capabilities = true,
		DefinesCapabilities = true,
		numExpectedDirectChildren = true,
		Children = true,
	}
	local PROPERTY_DENYLIST_LOWER = {}
	
	local propertyCache = {}
	local readOnlyPropertyCache = {}
	
	for propertyName in pairs(PROPERTY_DENYLIST) do
		PROPERTY_DENYLIST_LOWER[string.lower(propertyName)] = true
	end
	
	-- ── Helpers ──────────────────────────────────────────────────────────────────
	
	local function safeTostring(value)
		local success, result = pcall(tostring, value)
		return success and result or "<unprintable>"
	end
	
	local function safeReadProperty(instance, propertyName)
		local success, value = pcall(function()
			return instance[propertyName]
		end)
		return success, success and value or nil
	end
	
	local function safeReadStringProperty(instance, propertyName, fallback)
		local success, value = safeReadProperty(instance, propertyName)
		if success and type(value) == "string" and value ~= "" then
			return value
		end
		return fallback
	end
	
	local function isDeniedPropertyName(propertyName)
		if type(propertyName) ~= "string" or propertyName == "" then
			return true
		end
	
		return PROPERTY_DENYLIST[propertyName] == true or PROPERTY_DENYLIST_LOWER[string.lower(propertyName)] == true
	end
	
	-- ── Property name discovery via ReflectionService ────────────────────────────
	-- Uses GetPropertiesOfClass — the correct ReflectionService API.
	-- Returns a flat array of property descriptor tables, each with:
	--   .Name    (string)
	--   .Permits (table, optional) — has .Read/.Write fields if restricted
	
	local function getPropertyNamesForClass(className)
		if propertyCache[className] ~= nil then
			return propertyCache[className]
		end
	
		local ok, props = pcall(function()
			return ReflectionService:GetPropertiesOfClass(className)
		end)
	
		if not ok or type(props) ~= "table" then
			propertyCache[className] = {}
			readOnlyPropertyCache[className] = {}
			return {}
		end
	
		local names = {}
		local seenLowercaseNames = {}
		local readOnlyNames = {}
		for _, prop in ipairs(props) do
			local name = prop.Name
			if type(name) == "string" and not isDeniedPropertyName(name) then
				local canWrite = prop.Permits == nil
					or prop.Permits.Write ~= nil
					or prop.Permits.WriteParallel ~= nil
				local canRead = prop.Permits == nil
					or prop.Permits.Read ~= nil
					or prop.Permits.ReadParallel ~= nil
				local lowercaseName = string.lower(name)
				if not seenLowercaseNames[lowercaseName] and (canWrite or canRead) then
					seenLowercaseNames[lowercaseName] = true
					if not canWrite then
						readOnlyNames[name] = true
					end
					table.insert(names, name)
				end
			end
		end
	
		if #names == 0 then
			seenLowercaseNames = {}
	
			for _, prop in ipairs(props) do
				local name = prop.Name
				if type(name) == "string" and not isDeniedPropertyName(name) then
					local lowercaseName = string.lower(name)
					if not seenLowercaseNames[lowercaseName] then
						seenLowercaseNames[lowercaseName] = true
						readOnlyNames[name] = true
						table.insert(names, name)
					end
				end
			end
		end
	
		table.sort(names)
		propertyCache[className] = names
		readOnlyPropertyCache[className] = readOnlyNames
		return names
	end
	
	local function sortedPropertyNamesForClass(className)
		local names = table.clone(getPropertyNamesForClass(className))
		table.sort(names)
		return names
	end
	
	-- ── Value encoder ─────────────────────────────────────────────────────────────
	
	local function encodeNumber(value)
		local valueType = "float"
		if value == value
			and value ~= math.huge
			and value ~= -math.huge
			and math.floor(value) == value
		then
			valueType = "int"
		end
		return { type = valueType, value = value }
	end
	
	local function encodeValue(value)
		if value == nil then return nil end
	
		local valueType = typeof(value)
	
		if valueType == "boolean" then
			return { type = "bool", value = value }
		end
	
		if valueType == "number" then
			return encodeNumber(value)
		end
	
		if valueType == "string" then
			return { type = "string", value = value }
		end
	
		if valueType == "Vector3" then
			return { type = "Vector3", value = { value.X, value.Y, value.Z } }
		end
	
		if valueType == "CFrame" then
			return { type = "CFrame", value = { value:GetComponents() } }
		end
	
		if valueType == "Color3" then
			return { type = "Color3", value = { value.R, value.G, value.B } }
		end
	
		if valueType == "BrickColor" then
			return { type = "BrickColor", value = value.Number }
		end
	
		if valueType == "UDim2" then
			return {
				type = "UDim2",
				value = { value.X.Scale, value.X.Offset, value.Y.Scale, value.Y.Offset },
			}
		end
	
		if valueType == "UDim" then
			return { type = "UDim", value = { value.Scale, value.Offset } }
		end
	
		if valueType == "NumberRange" then
			return { type = "NumberRange", value = { value.Min, value.Max } }
		end
	
		if valueType == "EnumItem" then
			return { type = "EnumItem", value = safeTostring(value) }
		end
	
		if valueType == "Vector2" then
			return { type = "Vector2", value = { value.X, value.Y } }
		end
	
		if valueType == "Rect" then
			return {
				type = "Rect",
				value = { value.Min.X, value.Min.Y, value.Max.X, value.Max.Y },
			}
		end
	
		if valueType == "ColorSequence" then
			local keypoints = {}
			for _, kp in ipairs(value.Keypoints) do
				table.insert(keypoints, { time = kp.Time, color = { kp.Value.R, kp.Value.G, kp.Value.B } })
			end
			return { type = "ColorSequence", value = keypoints }
		end
	
		if valueType == "NumberSequence" then
			local keypoints = {}
			for _, kp in ipairs(value.Keypoints) do
				table.insert(keypoints, { time = kp.Time, value = kp.Value, envelope = kp.Envelope })
			end
			return { type = "NumberSequence", value = keypoints }
		end
	
		return { type = "unknown", raw = safeTostring(value) }
	end
	
	-- ── Attribute encoder ─────────────────────────────────────────────────────────
	
	local function encodeAttributes(instance)
		local success, attributes = pcall(function()
			return instance:GetAttributes()
		end)
		if not success or type(attributes) ~= "table" then return {} end
	
		local encoded = {}
		for attrName, attrValue in pairs(attributes) do
			encoded[attrName] = encodeValue(attrValue)
		end
		return encoded
	end
	
	-- ── Script source ─────────────────────────────────────────────────────────────
	
	local function safeScriptSource(instance, className)
		if not SCRIPT_CLASS_NAMES[className] then return nil end
		local success, source = safeReadProperty(instance, "Source")
		if success and type(source) == "string" then return source end
		return nil
	end
	
	-- ── Collection helpers ────────────────────────────────────────────────────────
	
	local function safeGetTags(instance)
		local success, tags = pcall(function()
			return CollectionService:GetTags(instance)
		end)
		return (success and type(tags) == "table") and tags or {}
	end
	
	local function safeGetChildren(instance)
		local success, children = pcall(function()
			return instance:GetChildren()
		end)
		return (success and type(children) == "table") and children or {}
	end
	
	-- ── Public API ────────────────────────────────────────────────────────────────
	
	function Serializer.serializeInstance(instance, deep)
		local className = safeReadStringProperty(instance, "ClassName", "Instance")
		local name = safeReadStringProperty(instance, "Name", className)
		local properties = {}
		local propertiesOrdered = {}
		local sortedKeys = {}
	
		local serialized = {
			name = name,
			className = className,
			properties = properties,
			_propertyOrder = sortedKeys,
			attributes = encodeAttributes(instance),
			tags = safeGetTags(instance),
			children = {},
		}
	
		local readOnlyNames = readOnlyPropertyCache[className] or {}
		for _, propertyName in ipairs(sortedPropertyNamesForClass(className)) do
			if isDeniedPropertyName(propertyName) then
				continue
			end
	
			local success, propertyValue = safeReadProperty(instance, propertyName)
			if success then
				local encodedValue = encodeValue(propertyValue)
				if encodedValue ~= nil then
					if readOnlyNames[propertyName] and type(encodedValue) == "table" then
						encodedValue = table.clone(encodedValue)
						encodedValue.readOnly = true
					end
					table.insert(propertiesOrdered, {
						k = propertyName,
						v = encodedValue,
					})
				end
			end
		end
	
		for _, pair in ipairs(propertiesOrdered) do
			properties[pair.k] = pair.v
			table.insert(sortedKeys, pair.k)
		end
	
		local source = safeScriptSource(instance, className)
		if source ~= nil then
			serialized.source = source
		end
	
		if deep then
			for _, child in ipairs(safeGetChildren(instance)) do
				table.insert(serialized.children, Serializer.serializeInstance(child, true))
			end
		end
	
		return serialized
	end
	
	return Serializer
	
end

__modules['sync/Deserializer'] = function(moduleRequire, script)
	local require = moduleRequire
	local ChangeHistoryService = game:GetService("ChangeHistoryService")
	local CollectionService = game:GetService("CollectionService")
	local PathUtil = require(script.Parent.Parent.util.PathUtil)
	
	local Deserializer = {}
	
	local READ_ONLY_INSTANCES = {
		["Workspace/Camera"] = true,
		["Workspace/Terrain"] = true,
	}
	local LOCKED_SERVICES = {
		Workspace = true,
		Players = true,
		Lighting = true,
		MaterialService = true,
		ReplicatedFirst = true,
		ReplicatedStorage = true,
		ServerScriptService = true,
		ServerStorage = true,
		StarterGui = true,
		StarterPack = true,
		StarterPlayer = true,
		Teams = true,
		SoundService = true,
		TextChatService = true,
	}
	local SCRIPT_CLASS_NAMES = {
		Script = true,
		LocalScript = true,
		ModuleScript = true,
	}
	
	local PROPERTY_DENYLIST = {
		Parent = true,
		Name = true,
		ClassName = true,
		Source = true,
		LinkedSource = true,
		ScriptGuid = true,
		Tags = true,
		Attributes = true,
		AttributesReplicate = true,
		AttributesSerialize = true,
		DataCost = true,
		UniqueId = true,
		HistoryId = true,
		Capabilities = true,
		DefinesCapabilities = true,
		numExpectedDirectChildren = true,
		Children = true,
	}
	
	local function readEncodedType(rawValue)
		if type(rawValue) ~= "table" then
			return nil
		end
	
		return rawValue.type or rawValue.Type
	end
	
	local function readEncodedValue(rawValue)
		if type(rawValue) ~= "table" then
			return rawValue
		end
	
		if rawValue.value ~= nil then
			return rawValue.value
		end
	
		return rawValue.Value
	end
	
	local function decodeEnumItem(enumText)
		if type(enumText) ~= "string" or enumText == "" then
			return nil
		end
	
		local segments = string.split(enumText, ".")
		if #segments >= 3 and segments[1] == "Enum" then
			local enumType = Enum[segments[2]]
			if enumType then
				return enumType[segments[3]]
			end
		elseif #segments >= 2 then
			local enumType = Enum[segments[1]]
			if enumType then
				return enumType[segments[2]]
			end
		end
	
		return nil
	end
	
	local function decodeValue(rawValue)
		if typeof(rawValue) ~= "table" then
			return rawValue
		end
	
		local encodedType = readEncodedType(rawValue)
		local encodedValue = readEncodedValue(rawValue)
	
		if type(encodedType) ~= "string" then
			return rawValue
		end
	
		if encodedType == "Vector2" and type(encodedValue) == "table" and #encodedValue >= 2 then
			return Vector2.new(encodedValue[1], encodedValue[2])
		end
	
		if encodedType == "Vector3" and type(encodedValue) == "table" and #encodedValue >= 3 then
			return Vector3.new(encodedValue[1], encodedValue[2], encodedValue[3])
		end
	
		if encodedType == "Color3" and type(encodedValue) == "table" and #encodedValue >= 3 then
			return Color3.new(encodedValue[1], encodedValue[2], encodedValue[3])
		end
	
		if encodedType == "UDim2" and type(encodedValue) == "table" and #encodedValue >= 4 then
			return UDim2.new(encodedValue[1], encodedValue[2], encodedValue[3], encodedValue[4])
		end
	
		if encodedType == "UDim" and type(encodedValue) == "table" and #encodedValue >= 2 then
			return UDim.new(encodedValue[1], encodedValue[2])
		end
	
		if encodedType == "CFrame" and type(encodedValue) == "table" then
			return CFrame.new(unpack(encodedValue))
		end
	
		if encodedType == "BrickColor" and type(encodedValue) == "string" then
			local success, result = pcall(function()
				return BrickColor.new(encodedValue)
