	local function isReadOnlyPath(pathValue)
		for protectedPath in pairs(READ_ONLY_INSTANCES) do
			if isSameOrDescendantPath(pathValue, protectedPath) then
				return true
			end
		end
	
		return false
	end
	
	local function isLockedServiceName(serviceName)
		return LOCKED_SERVICES[serviceName] == true
	end
	
	local function isLockedServiceInstance(instance)
		return instance ~= nil and instance.Parent == game and isLockedServiceName(instance.Name)
	end
	
	local function isRuntimePlayerInstance(instance)
		local current = instance
		while current and current ~= game do
			local success, isPlayer = pcall(function()
				return current:IsA("Player")
			end)
			if success and isPlayer then
				return true
			end
			current = current.Parent
		end
	
		return false
	end
	
	local function shouldProtectFromRemoval(instance, pathValue)
		if instance == nil then
			return true
		end
	
		if isReadOnlyPath(pathValue) then
			return true
		end
	
		if isLockedServiceInstance(instance) then
			return true
		end
	
		if isRuntimePlayerInstance(instance) then
			return true
		end
	
		return false
	end
	
	local function countNodeInstances(node)
		local total = 1
		for _, childNode in ipairs(node.children or {}) do
			total += countNodeInstances(childNode)
		end
		return total
	end
	
	local function countTreeInstances(tree)
		local total = 0
		for _, serviceNode in ipairs(tree.services or {}) do
			total += countNodeInstances(serviceNode)
		end
		return total
	end
	
	local function createProgressState(options, total)
		if type(options) ~= "table" then
			return nil
		end
	
		local onProgress = type(options.onProgress) == "function" and options.onProgress or nil
		local onServiceStart = type(options.onServiceStart) == "function" and options.onServiceStart or nil
		local onServiceProgress = type(options.onServiceProgress) == "function" and options.onServiceProgress or nil
		local onServiceComplete = type(options.onServiceComplete) == "function" and options.onServiceComplete or nil
	
		if onProgress == nil and onServiceStart == nil and onServiceProgress == nil and onServiceComplete == nil then
			return nil
		end
	
		return {
			done = 0,
			total = total,
			removed = 0,
			batchSize = type(options.batchSize) == "number" and math.max(1, options.batchSize) or 50,
			onProgress = onProgress,
			onServiceStart = onServiceStart,
			onServiceProgress = onServiceProgress,
			onServiceComplete = onServiceComplete,
			currentService = nil,
			currentServiceDone = 0,
			currentServiceTotal = 0,
			currentServiceRemoved = 0,
			currentServiceIsLast = false,
		}
	end
	
	local function beginServiceProgress(progressState, serviceName, total, isLastService)
		if progressState == nil then
			return
		end
	
		progressState.currentService = serviceName
		progressState.currentServiceDone = 0
		progressState.currentServiceTotal = total
		progressState.currentServiceRemoved = 0
		progressState.currentServiceIsLast = isLastService == true
	
		if progressState.onServiceStart then
			progressState.onServiceStart(serviceName, total, isLastService == true)
		end
	end
	
	local function completeServiceProgress(progressState)
		if progressState == nil or progressState.currentService == nil then
			return
		end
	
		if progressState.onServiceComplete then
			progressState.onServiceComplete(
				progressState.currentService,
				progressState.currentServiceDone,
				progressState.currentServiceTotal,
				progressState.currentServiceIsLast == true,
				progressState.currentServiceRemoved
			)
		end
	
		progressState.currentService = nil
		progressState.currentServiceDone = 0
		progressState.currentServiceTotal = 0
		progressState.currentServiceRemoved = 0
		progressState.currentServiceIsLast = false
	end
	
	local function markProgress(progressState)
		if progressState == nil then
			return
		end
	
		progressState.done += 1
		if progressState.currentService ~= nil then
			progressState.currentServiceDone += 1
			if progressState.onServiceProgress then
				local serviceDone = progressState.currentServiceDone
				local serviceTotal = progressState.currentServiceTotal
				if serviceDone % progressState.batchSize == 0 or serviceDone >= serviceTotal then
					progressState.onServiceProgress(progressState.currentService, serviceDone, serviceTotal)
				end
			end
		end
	
		if progressState.onProgress and (progressState.done % progressState.batchSize == 0 or progressState.done >= progressState.total) then
			progressState.onProgress(progressState.done, progressState.total)
		end
	end
	
	local function markRemoval(progressState)
		if progressState == nil then
			return
		end
	
		progressState.removed += 1
		if progressState.currentService ~= nil then
			progressState.currentServiceRemoved += 1
		end
	end
	
	local function getServiceRoot(serviceName)
		local success, service = pcall(function()
			return game:GetService(serviceName)
		end)
	
		if success then
			return service
		end
	
		return game:FindFirstChild(serviceName)
	end
	
	local function findOrCreateChildBySegment(parent, segment)
		local exactMatch = parent:FindFirstChild(segment)
		if exactMatch then
			return exactMatch, exactMatch.Name
		end
	
		local baseName, ordinal = PathUtil.parsePathSegment(segment)
		local matches = {}
	
		for _, child in ipairs(parent:GetChildren()) do
			if child.Name == baseName then
				table.insert(matches, child)
			end
		end
	
		if ordinal == nil then
			return matches[1], baseName
		end
	
		while #matches < ordinal do
			local child = Instance.new("Folder")
			child.Name = baseName
			child.Parent = parent
			table.insert(matches, child)
		end
	
		return matches[ordinal], baseName
	end
	
	local function resolveNameForSegment(parent, segment, currentInstance)
		local exactMatch = parent and parent:FindFirstChild(segment) or nil
		if exactMatch ~= nil and exactMatch ~= currentInstance then
			return segment
		end
	
		local baseName, ordinal = PathUtil.parsePathSegment(segment)
		if ordinal ~= nil and parent ~= nil then
			local matchCount = 0
			for _, child in ipairs(parent:GetChildren()) do
				if child ~= currentInstance and child.Name == baseName then
					matchCount += 1
				end
			end
	
			if matchCount >= (ordinal - 1) then
				return baseName
			end
		end
	
		return segment
	end
	
	local function findInstanceByPath(pathValue)
		local segments = splitPath(pathValue)
		if #segments == 0 then
			return nil
		end
	
		local current = getServiceRoot(segments[1])
		if not current then
			return nil
		end
	
		for index = 2, #segments do
			current = findChildBySegment(current, segments[index])
			if not current then
				return nil
			end
		end
	
		return current
	end
	
	local function ensureParentForPath(pathValue)
		local segments = splitPath(pathValue)
		if #segments <= 1 then
			return nil, "Expected an instance path below a service."
		end
	
		local current = getServiceRoot(segments[1])
		if not current then
			return nil, "Missing service " .. tostring(segments[1])
		end
	
		for index = 2, #segments - 1 do
			local segment = segments[index]
			local child, childName = findOrCreateChildBySegment(current, segment)
			if not child then
				child = Instance.new("Folder")
				child.Name = childName
				child.Parent = current
			end
			current = child
		end
	
		return current
	end
	
	local applyNode
	
	local function planDesiredChildren(parentInstance, childNodes)
		local plannedChildren = {}
		local matchedInstances = {}
	
		for _, childNode in ipairs(childNodes or {}) do
			local childInstance = findCandidateChild(parentInstance, childNode)
			if childInstance ~= nil and matchedInstances[childInstance] == true then
				childInstance = nil
			end
	
			if childInstance ~= nil then
				matchedInstances[childInstance] = true
			end
	
			table.insert(plannedChildren, {
				node = childNode,
				instance = childInstance,
			})
		end
	
		return plannedChildren, matchedInstances
	end
	
	local function reconcileChildren(parentInstance, matchedInstances, progressState)
		for _, childInstance in ipairs(parentInstance:GetChildren()) do
			if matchedInstances[childInstance] ~= true then
				local childPath = PathUtil.getInstancePath(childInstance)
				if not shouldProtectFromRemoval(childInstance, childPath) then
					local removed = pcall(function()
						childInstance:Destroy()
					end)
					if removed then
						markRemoval(progressState)
					end
				end
			end
		end
	end
	
	local function applyChildrenRecursive(parentInstance, parentPath, childNodes, progressState, options)
		local plannedChildren, matchedInstances = planDesiredChildren(parentInstance, childNodes)
		if type(options) == "table" and options.reconcileRemovals == true then
			reconcileChildren(parentInstance, matchedInstances, progressState)
		end
	
		for _, plannedChild in ipairs(plannedChildren) do
			local childNode = plannedChild.node
			local childSegment = childNode._pathSegment or childNode.pathSegment or childNode.name
			local childPath = joinPath(parentPath, childSegment)
			if isReadOnlyPath(childPath) then
				markProgress(progressState)
				continue
			end
	
			local childInstance = plannedChild.instance
			if not childInstance then
				childInstance = createInstanceForNode(childNode)
				childInstance.Name = childNode.name
				childInstance.Parent = parentInstance
			end
	
			applyNode(childInstance, childNode, childPath, progressState, options)
		end
	end
	
	applyNode = function(instance, node, nodePath, progressState, options)
		if isReadOnlyPath(nodePath) then
			markProgress(progressState)
			return true
		end
	
		instance.Name = node.name
	
		applyAttributesAdditive(instance, node.attributes)
		applyTagsAdditive(instance, node.tags)
		local deferredPrimaryPart = applyProperties(instance, node)
		markProgress(progressState)
		applyChildrenRecursive(instance, nodePath, node.children, progressState, options)
	
		if type(deferredPrimaryPart) == "table" then
			local referenceValue = deferredPrimaryPart.value or deferredPrimaryPart.Value or deferredPrimaryPart
			local targetName = type(referenceValue) == "table" and referenceValue.name or nil
			if type(targetName) == "string" and targetName ~= "" then
				local target = instance:FindFirstChild(targetName, true)
				if target then
					pcall(function()
						instance.PrimaryPart = target
					end)
				end
			end
		end
	end
	
	local function applyServiceNode(serviceNode, progressState, options)
		local service = getServiceRoot(serviceNode.name)
		if not service then
			return false, "Missing service " .. tostring(serviceNode.name)
		end
	
		applyAttributesAdditive(service, serviceNode.attributes)
		applyTagsAdditive(service, serviceNode.tags)
		applyProperties(service, serviceNode)
		markProgress(progressState)
		applyChildrenRecursive(service, serviceNode.name, serviceNode.children, progressState, options)
	
		return true
	end
	
	function Deserializer.applySyncInstance(pathValue, node, options)
		if type(pathValue) ~= "string" or type(node) ~= "table" then
			return false, "Expected path and node."
		end
	
		if isReadOnlyPath(pathValue) then
			return true
		end
	
		local segments = splitPath(pathValue)
		if #segments == 0 then
			return false, "Expected a Roblox path."
		end
	
		ChangeHistoryService:SetWaypoint("Before RoSync Sync Instance")
		local progressState = createProgressState(options, countNodeInstances(node))
	
		if #segments == 1 then
			local success, result = applyServiceNode({
				name = node.name or segments[1],
				className = node.className or segments[1],
				properties = node.properties or {},
				attributes = node.attributes or {},
				tags = node.tags or {},
				source = node.source,
				children = node.children or {},
				_pathSegment = node._pathSegment or segments[1],
			}, progressState, options)
			ChangeHistoryService:SetWaypoint("After RoSync Sync Instance")
			return success, result, progressState and progressState.done or countNodeInstances(node), progressState and progressState.removed or 0
		end
	
		local parent, parentError = ensureParentForPath(pathValue)
		if not parent then
			return false, parentError
		end
	
		local nodeName, _ = PathUtil.parsePathSegment(segments[#segments])
		local childNode = {
			name = node.name or nodeName,
			className = node.className or "Folder",
			properties = node.properties or {},
			attributes = node.attributes or {},
			tags = node.tags or {},
			source = node.source,
			children = node.children or {},
			_pathSegment = node._pathSegment or segments[#segments],
		}
	
		local instance = findCandidateChild(parent, childNode)
		if not instance then
			instance = createInstanceForNode(childNode)
			instance.Name = childNode.name
			instance.Parent = parent
		end
	
		applyNode(instance, childNode, pathValue, progressState, options)
		ChangeHistoryService:SetWaypoint("After RoSync Sync Instance")
		return true, nil, progressState and progressState.done or countNodeInstances(childNode), progressState and progressState.removed or 0
	end
	
	function Deserializer.removeAtPath(pathValue)
		if isReadOnlyPath(pathValue) then
			return true
		end
	
		local instance = findInstanceByPath(pathValue)
		if not instance then
			return false, "Instance not found at " .. tostring(pathValue)
		end
	
		if instance == game then
			return false, "Cannot remove the DataModel root."
		end
	
		if isLockedServiceInstance(instance) then
			return false, "Cannot remove locked service " .. tostring(instance.Name)
		end
	
		ChangeHistoryService:SetWaypoint("Before RoSync Remove")
		local success, removeError = pcall(function()
			instance:Destroy()
		end)
		ChangeHistoryService:SetWaypoint("After RoSync Remove")
	
		if not success then
			return false, tostring(removeError)
		end
	
		return true
	end
	
	function Deserializer.renameAtPath(oldPath, newPath)
		if isReadOnlyPath(oldPath) or isReadOnlyPath(newPath) then
			return true
		end
	
		local instance = findInstanceByPath(oldPath)
		if not instance then
			return false, "Instance not found at " .. tostring(oldPath)
		end
	
		if isLockedServiceInstance(instance) then
			return false, "Cannot rename or move locked service " .. tostring(instance.Name)
		end
	
		local segments = splitPath(newPath)
		if #segments == 0 then
			return false, "Expected a destination Roblox path."
		end
	
		local nextParent = nil
		if #segments > 1 then
			local parent, parentError = ensureParentForPath(newPath)
			if not parent then
				return false, parentError
			end
			nextParent = parent
		end
	
		ChangeHistoryService:SetWaypoint("Before RoSync Rename")
	
		local success, renameError = pcall(function()
			if nextParent then
				instance.Parent = nextParent
			end
			local nextName = resolveNameForSegment(instance.Parent, segments[#segments], instance)
			instance.Name = nextName
		end)
	
		ChangeHistoryService:SetWaypoint("After RoSync Rename")
	
		if not success then
			return false, tostring(renameError)
		end
	
		return true
	end
	
	function Deserializer.applyTree(tree, options)
		if type(tree) ~= "table" or type(tree.services) ~= "table" then
			return false, "Expected a tree with services."
		end
	
		local errors = {}
		local progressState = createProgressState(options, countTreeInstances(tree))
		ChangeHistoryService:SetWaypoint("Before RoSync Apply")
	
		for index, serviceNode in ipairs(tree.services) do
			beginServiceProgress(progressState, serviceNode.name, countNodeInstances(serviceNode), index == #tree.services)
			local success, result = applyServiceNode(serviceNode, progressState, options)
			completeServiceProgress(progressState)
			if not success then
				table.insert(errors, tostring(result))
			end
		end
	
		ChangeHistoryService:SetWaypoint("After RoSync Apply")
	
		if #errors > 0 then
			return false, table.concat(errors, "\n")
		end
	
		return true, nil, progressState and progressState.done or countTreeInstances(tree), progressState and progressState.removed or 0
	end
	
	return Deserializer
	
end

__modules['util/PathUtil'] = function(moduleRequire, script)
	local require = moduleRequire
	local PathUtil = {}
	
	local function getChildren(parent)
		local success, children = pcall(function()
			return parent:GetChildren()
		end)
	
		if success and type(children) == "table" then
			return children
		end
	
		return {}
	end
	
	local function getSiblingOccurrence(instance)
		local parent = instance and instance.Parent
		if parent == nil or parent == game then
			return nil, 1
		end
	
		local siblings = getChildren(parent)
		local total = 0
		local ordinal = 0
		for _, sibling in ipairs(siblings) do
			if sibling.Name == instance.Name then
				total += 1
				if sibling == instance then
					ordinal = total
				end
			end
		end
	
		if ordinal == 0 then
			ordinal = 1
		end
	
		return ordinal, total
	end
	
	function PathUtil.encodePathSegment(name, ordinal, total)
		if type(name) ~= "string" or name == "" then
			name = "Instance"
		end
	
		if type(total) == "number" and total > 1 then
			local safeOrdinal = type(ordinal) == "number" and math.max(1, math.floor(ordinal)) or 1
			if safeOrdinal > 1 then
				return string.format("%s_%d", name, safeOrdinal)
			end
		end
	
		return name
	end
	
	function PathUtil.parsePathSegment(segment)
		if type(segment) ~= "string" or segment == "" then
			return "Instance", nil
		end
	
		local legacyMarker = ".__rosync_"
		local legacyMarkerStart = string.find(segment, legacyMarker, 1, true)
		if legacyMarkerStart ~= nil then
			local baseName = string.sub(segment, 1, legacyMarkerStart - 1)
			local ordinalText = string.sub(segment, legacyMarkerStart + string.len(legacyMarker))
			local ordinal = tonumber(ordinalText)
			if baseName ~= "" and ordinal ~= nil and ordinal >= 1 then
				return baseName, ordinal
			end
		end
	
		local baseName, ordinalText = string.match(segment, "^(.*)_(%d+)$")
		local ordinal = tonumber(ordinalText)
		if baseName ~= nil and baseName ~= "" and ordinal ~= nil and ordinal >= 2 then
			return baseName, ordinal
		end
	
		return segment, nil
	end
	
	function PathUtil.getInstanceSegment(instance)
		if instance == nil then
			return "Instance"
		end
	
		local ordinal, total = getSiblingOccurrence(instance)
		return PathUtil.encodePathSegment(instance.Name, ordinal, total)
	end
	
	function PathUtil.getInstancePath(instance)
		local segments = {}
		local current = instance
	
		while current and current ~= game do
			table.insert(segments, 1, PathUtil.getInstanceSegment(current))
			current = current.Parent
		end
	
		return table.concat(segments, "/")
	end
	
	return PathUtil
	
end

__modules['main.client'](__require, script)
